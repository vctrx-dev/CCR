{
  "name": "@ccr/reviewer",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "description": "LLM-powered code review for educational AI fairness — GitHub Action, CLI, agent skill",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ccr": "./dist/cli/index.cjs"
  },
  "files": ["dist", "prompts", "action.yml"],
  "scripts": {
    "prepare": "husky",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:e2e": "vitest run tests/e2e/",
    "test:changed": "node scripts/audit.mjs --blast",
    "test:changed:print": "node scripts/audit.mjs --blast --print",
    "audit": "node scripts/audit.mjs",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "self-review:local": "npm run build && node dist/cli/index.cjs review --local --criteria explainability,ai-governance,privacy-consent",
    "self-review:ci": "npm run build && node dist/cli/index.cjs review --fixture self-review-pr --criteria explainability,ai-governance,privacy-consent",
    "fixture:record": "tsx scripts/record-pr.ts",
    "fixture:replay": "tsx scripts/replay-review.ts",
    "fixture:refresh-all": "tsx scripts/regenerate-fixtures.ts",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "commander": "^15.0.0",
    "picomatch": "^4.0.0",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "husky"]
  },
  "lint-staged": {
    "*.{ts,tsx}": ["biome check --write", "biome format --write"],
    "*.json": ["biome format --write"]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^21.2.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
